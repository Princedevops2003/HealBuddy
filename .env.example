# Copy to .env for local development (never commit real .env).
# On Render, set these in the dashboard: Environment → Environment Variables.

# Required in production (use long random strings)
SECRET_KEY=replace-with-a-long-random-string
JWT_SECRET=replace-with-another-long-random-string

# Optional: leave unset for local SQLite in ./instance/healbuddy.db
# For Render PostgreSQL (recommended for real data), paste the Internal Database URL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Local dev only
FLASK_DEBUG=true

# Optional: CORS is open by default; tighten in production if needed (requires code change).
